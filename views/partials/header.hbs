<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DealPlate Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; background: #f4f5f7; color: #1f2430; display: flex; min-height: 100vh; }
    a { text-decoration: none; color: inherit; }
    .sidebar { width: 220px; background: #1f2430; color: #cfd3dc; padding: 20px 0; position: fixed; height: 100vh; }
    .sidebar h1 { color: #fff; font-size: 18px; padding: 0 20px 18px; border-bottom: 1px solid #333a48; }
    .sidebar nav { margin-top: 12px; display: flex; flex-direction: column; }
    .sidebar nav a { padding: 12px 20px; font-size: 14px; border-left: 3px solid transparent; }
    .sidebar nav a:hover { background: #2a3140; color: #fff; }
    .sidebar nav a.active { background: #2a3140; color: #fff; border-left-color: #ff6a3d; }
    .sidebar .logout { margin-top: 24px; color: #ff8a6a; }
    .content { margin-left: 220px; padding: 28px 32px; width: calc(100% - 220px); }
    .content h2 { font-size: 22px; margin-bottom: 20px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; margin-bottom: 28px; }
    .card { background: #fff; border: 1px solid #e6e8ec; border-radius: 14px; padding: 18px; }
    .card .label { font-size: 13px; color: #6b7280; }
    .card .value { font-size: 28px; font-weight: 700; margin-top: 6px; }
    table { width: 100%; background: #fff; border-collapse: collapse; border: 1px solid #e6e8ec; border-radius: 12px; overflow: hidden; }
    th, td { text-align: left; padding: 11px 14px; font-size: 13px; border-bottom: 1px solid #eef0f3; }
    th { background: #fafbfc; color: #6b7280; font-weight: 600; }
    tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge.APPROVED { background: #e6f7ec; color: #1a8a4b; }
    .badge.PENDING { background: #fff4e0; color: #b8730a; }
    .badge.REJECTED { background: #fde7e7; color: #c0392b; }
    .badge.DRAFT { background: #eceef1; color: #5b6472; }
    .btn { display: inline-block; padding: 6px 12px; border: none; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .btn.approve { background: #1a8a4b; color: #fff; }
    .btn.reject { background: #b8730a; color: #fff; }
    .btn.delete { background: #c0392b; color: #fff; }
    .filters { margin-bottom: 16px; }
    .filters a { padding: 6px 12px; border: 1px solid #d7dae0; border-radius: 20px; font-size: 13px; margin-right: 6px; background: #fff; }
    .filters a.active { background: #1f2430; color: #fff; border-color: #1f2430; }
    form.inline { display: inline; }
    .muted { color: #9aa1ad; font-size: 12px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h1>🍽️ DealPlate</h1>
    <nav>
      <a href="/admin" class="{{#if (eq nav 'dashboard')}}active{{/if}}">Dashboard</a>
      <a href="/admin/users" class="{{#if (eq nav 'users')}}active{{/if}}">Users</a>
      <a href="/admin/restaurants" class="{{#if (eq nav 'restaurants')}}active{{/if}}">Restaurants</a>
      <a href="/admin/promotions" class="{{#if (eq nav 'promotions')}}active{{/if}}">Promotions</a>
      <a href="/admin/audit" class="{{#if (eq nav 'audit')}}active{{/if}}">Audit Logs</a>
      <a href="/admin/logout" class="logout">Log out</a>
    </nav>
  </aside>
  <main class="content">
