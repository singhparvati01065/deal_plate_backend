<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DealPlate Admin — Login</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; background: #1f2430; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .box { background: #fff; padding: 36px 32px; border-radius: 16px; width: 340px; box-shadow: 0 12px 40px rgba(0,0,0,.3); }
    .box h1 { font-size: 22px; margin-bottom: 4px; }
    .box p { color: #6b7280; font-size: 13px; margin-bottom: 22px; }
    label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: #374151; }
    input { width: 100%; padding: 11px 12px; border: 1px solid #d7dae0; border-radius: 10px; font-size: 14px; margin-bottom: 16px; }
    button { width: 100%; padding: 12px; background: #ff6a3d; color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; }
    .err { background: #fde7e7; color: #c0392b; padding: 10px 12px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }
  </style>
</head>
<body>
  <form class="box" method="post" action="/admin/login">
    <h1>🍽️ DealPlate Admin</h1>
    <p>Sign in to manage the platform</p>
    {{#if error}}<div class="err">{{error}}</div>{{/if}}
    <label>Email</label>
    <input type="email" name="email" placeholder="admin@dealplate.com" required />
    <label>Password</label>
    <input type="password" name="password" placeholder="••••••••" required />
    <button type="submit">Log in</button>
  </form>
</body>
</html>
