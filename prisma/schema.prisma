// DealPlate Prisma schema — restaurant promotions marketplace
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER // consumer
  OWNER
  STAFF
  ADMIN
}

enum PromotionType {
  FLYER
  DISCOUNT
  BUFFET
  CATERING
  COUPON
  EVENT
}

enum PromotionStatus {
  DRAFT
  PENDING // awaiting admin approval
  APPROVED // approved; live/scheduled/expired derived from dates
  REJECTED
}

enum SubscriptionPlan {
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum StaffRole {
  MANAGER
  STAFF
}

model User {
  id          String     @id @default(uuid())
  firebaseUid String     @unique
  email       String     @unique
  name        String?
  photoUrl    String?
  role        Role?
  restaurant  Restaurant? // set only for OWNER
  favorites   Favorite[]
  staffOf     StaffMember[]
  devices     DeviceToken[]
  notifications Notification[]
  coupons     Coupon[]
  loyaltyEvents LoyaltyEvent[]
  referralCode String? // app-generated, uniqueness enforced in code
  referralsMade    Referral[] @relation("referrals_made")
  referralReceived Referral?  @relation("referral_received")
  cateringRequests CateringRequest[]
  reviews     Review[]
  latitude    Float? // last known location (for geo-targeted alerts)
  longitude   Float?
  lastSeenAt  DateTime? // updated on auth sync (for active-user metrics)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // new_promo | favorite | expiring | geo | campaign
  title       String
  body        String
  promotionId String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model CateringPackage {
  id             String     @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  pricePerPerson Float?
  minGuests      Int?
  imageUrl       String?
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  requests       CateringRequest[]

  @@index([restaurantId])
}

model CateringRequest {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  packageId    String?
  package      CateringPackage? @relation(fields: [packageId], references: [id])
  eventDate    DateTime
  guests       Int
  message      String?
  contactPhone String?
  status       String           @default("PENDING") // PENDING | RESPONDED | CLOSED
  createdAt    DateTime         @default(now())

  @@index([restaurantId])
  @@index([userId])
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referrer       User     @relation("referrals_made", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String   @unique
  referred       User     @relation("referral_received", fields: [referredUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([referrerId])
}

model LoyaltyEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String // coupon_redeemed | bonus | ...
  refId     String? // e.g. coupon id
  createdAt DateTime @default(now())

  @@index([userId])
}

model Coupon {
  id           String     @id @default(uuid())
  code         String     @unique
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotionId  String
  promotion    Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       String     @default("ACTIVE") // ACTIVE | REDEEMED
  redeemedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([restaurantId])
}

model Restaurant {
  id           String        @id @default(uuid())
  ownerId      String        @unique
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  cuisine      String?
  description  String?
  phone        String?
  addressLine  String?
  city         String?
  state        String?
  zip          String?
  latitude     Float?
  longitude    Float?
  coverImageUrl String?
  logoUrl      String?
  priceRange   String?
  rating       Float         @default(0)
  reviewCount  Int           @default(0)
  isOpen       Boolean       @default(true)
  suspended    Boolean       @default(false) // admin-suspended; hidden from consumers
  photos       String[]      @default([])
  promotions   Promotion[]
  staff        StaffMember[]
  menuItems    MenuItem[]
  campaigns    PushCampaign[]
  coupons      Coupon[]
  cateringPackages CateringPackage[]
  cateringRequests CateringRequest[]
  reviews      Review[]
  subscription Subscription?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([latitude, longitude])
  @@index([zip])
  @@index([city])
}

model Review {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating       Int // 1..5 stars
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, restaurantId]) // one review per user per restaurant (editable)
  @@index([restaurantId])
}

model Promotion {
  id           String          @id @default(uuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         PromotionType
  category     String?
  title        String
  description  String?
  badge        String?
  imageUrl     String?
  flyerPdfUrl  String?
  eventAt      DateTime? // specific date/time for EVENT-type promotions
  startDate    DateTime
  endDate      DateTime
  status       PromotionStatus @default(PENDING)
  featured     Boolean         @default(false)
  views        Int             @default(0)
  clicks       Int             @default(0)
  flyerViews   Int             @default(0)
  expiringNotified Boolean      @default(false)
  favorites    Favorite[]
  coupons      Coupon[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([restaurantId])
  @@index([type])
  @@index([category])
  @@index([status])
}

model Favorite {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, promotionId])
  @@index([userId])
}

model Subscription {
  id               String             @id @default(uuid())
  restaurantId     String             @unique
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan   @default(STARTER)
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  promosLimit      Int                @default(2)
  promosUsed       Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model StaffMember {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  email        String
  photoUrl     String?
  role         StaffRole  @default(STAFF)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model MenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float?
  imageUrl     String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model PushCampaign {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  title        String
  message      String
  audience     String     @default("all") // all | favorites | nearby
  recipients   Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String? // ios / android
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String? // user id of who performed the action
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
